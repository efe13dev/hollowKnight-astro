---
// No props de momento
---

<section
  id="inicio"
  class="hero min-h-screen pt-20 pb-16 flex items-center relative overflow-hidden"
  style="background-image: url('/img/202310192349115_5.jpg.webp'); background-size: cover; background-position: center;"
>
  <!-- Layered atmospheric overlays -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/80 via-[#060610]/70 to-[#060610]"
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-r from-[#060610]/90 via-transparent to-transparent"
  >
  </div>

  <!-- Canvas para partículas atmosféricas (Esporas / Polvo) -->
  <canvas
    id="hero-particles"
    class="absolute inset-0 z-0 pointer-events-none opacity-60"></canvas>

  <!-- Parallax Background Layer -->
  <div
    class="parallax absolute inset-0 opacity-20"
    data-speed="0.3"
    style="background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), var(--glow-purple) 0%, transparent 50%);"
  >
  </div>

  <!-- Decorative vertical line -->
  <div
    class="absolute left-[8%] top-[15%] bottom-[15%] w-px bg-gradient-to-b from-transparent via-[var(--accent-color)]/30 to-transparent hidden lg:block"
  >
  </div>

  <div class="max-w-2xl z-10 text-left pl-8 md:pl-16 lg:pl-24 fade-in">
    <span
      class="inline-block text-[var(--tertiary-color)] font-mono text-xs tracking-[0.3em] uppercase mb-4 opacity-70"
      >// Bienvenido a las profundidades</span
    >
    <h1
      class="text-4xl md:text-5xl lg:text-7xl font-cinzel font-bold mb-6 text-white leading-[1.1] tracking-tight"
      style="text-shadow: 0 0 40px rgba(155,109,255,0.3), 0 2px 10px rgba(0,0,0,0.8);"
    >
      Descubre el Reino de <span
        class="hallownest-animated inline-block bg-gradient-to-r from-[var(--accent-color)] via-[var(--tertiary-color)] to-[var(--accent-color)] bg-clip-text text-transparent"
        >Hallownest</span
      >
    </h1>
    <p
      class="text-lg md:text-xl text-white/80 mb-10 max-w-[85%] slide-in-left font-body leading-relaxed"
    >
      Un mundo de maravillas y peligros te espera bajo la superficie. Explora
      cavernas antiguas, lucha contra criaturas feroces y descubre secretos
      olvidados en esta aventura de acción y plataformas.
    </p>
    <div class="flex flex-wrap gap-4 mt-8 slide-in-right">
      <a
        href="https://www.youtube.com/watch?v=UAO2urG23S4"
        target="_blank"
        class="btn bg-gradient-to-r from-[var(--secondary-color)] to-[var(--accent-color)] text-white shadow-lg glow-hover font-cinzel text-sm tracking-wider uppercase"
        style="box-shadow: 0 4px 20px rgba(155,109,255,0.3);">Ver Tráiler</a
      >
      <a
        href="#personajes"
        class="btn border border-white/20 text-white/90 hover:border-[var(--accent-color)] hover:text-white hover:bg-white/5 transition-all duration-300 font-cinzel text-sm tracking-wider uppercase backdrop-blur-sm"
        >Explorar Personajes</a
      >
    </div>
  </div>
  <div
    class="hero-image absolute right-[5%] bottom-[8%] max-w-[18%] drop-shadow-lg hidden md:block parallax"
    data-speed="0.8"
  >
    <img
      src="/img/caballerito.png"
      alt="El Caballero en Hallownest"
      id="hero-knight-image"
      class="brightness-90 float-animation cursor-pointer hover:scale-110 transition-transform duration-500"
      style="filter: drop-shadow(0 0 30px rgba(155,109,255,0.3));"
    />
  </div>
</section>

<script>
  // Dust Particles System for Hero
  const canvas = document.getElementById(
    "hero-particles",
  ) as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext("2d");
    if (ctx) {
      let width = (canvas.width = window.innerWidth);
      let height = (canvas.height = window.innerHeight);

      window.addEventListener("resize", () => {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
      });

      const particles: {
        x: number;
        y: number;
        r: number;
        vx: number;
        vy: number;
      }[] = [];
      const particleCount = window.innerWidth < 768 ? 40 : 100;

      for (let i = 0; i < particleCount; i++) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          r: Math.random() * 2 + 0.5,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4 - 0.2, // Slight upward drift
        });
      }

      function draw() {
        if (!ctx) return;
        ctx.clearRect(0, 0, width, height);

        for (let i = 0; i < particleCount; i++) {
          const p = particles[i];
          ctx.beginPath();
          // Add a soft glow effect to particles
          ctx.fillStyle = `rgba(155, 109, 255, ${Math.random() * 0.3 + 0.2})`;
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2, true);
          ctx.fill();
        }
      }

      function update() {
        for (let i = 0; i < particleCount; i++) {
          const p = particles[i];
          p.x += p.vx;
          p.y += p.vy;

          // Wrap around with slight random repositioning
          if (p.x > width + 5) p.x = -5;
          else if (p.x < -5) p.x = width + 5;

          if (p.y > height + 5) {
            p.y = -5;
            p.x = Math.random() * width;
          } else if (p.y < -5) {
            p.y = height + 5;
            p.x = Math.random() * width;
          }
        }
        draw();
        requestAnimationFrame(update);
      }

      update();
    }
  }
</script>
