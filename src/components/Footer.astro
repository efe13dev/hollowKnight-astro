---
// No props de momento
---

<footer
  class="footer relative pt-20 pb-10 px-6 overflow-hidden"
  style="background: linear-gradient(180deg, #07070d 0%, #080814 40%, #02020a 100%); border-top: 1px solid rgba(155,109,255,0.12);"
>
  <div
    class="absolute inset-0 opacity-20"
    style="background: radial-gradient(circle at 20% 10%, rgba(155,109,255,0.35), transparent 35%), radial-gradient(circle at 80% 80%, rgba(0,200,255,0.45), transparent 35%);"
  >
  </div>

  <div
    class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, var(--accent-color), var(--tertiary-color), var(--accent-color), transparent);"
  >
  </div>

  <div
    class="footer-content max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-4 gap-10 md:gap-16 mb-14 relative z-10"
  >
    <div class="footer-brand space-y-4">
      <img
        src="/img/hollow-knight-4272059.webp"
        alt="Silueta del Caballero de Hollow Knight"
        loading="lazy"
        decoding="async"
        class="h-10 w-auto opacity-90"
      />
      <h3 class="text-xl md:text-2xl font-cinzel text-white font-bold">
        Hallownest
      </h3>
      <p class="text-white/50 text-sm leading-relaxed max-w-[280px]">
        Un misticismo de sombras y leyenda. Sigue explorando este mundo y sus
        enigmas.
      </p>
    </div>

    <div>
      <h4
        class="font-cinzel text-xs tracking-[0.2em] uppercase text-white/80 mb-4"
      >
        Navegación
      </h4>
      <ul class="space-y-3">
        <li>
          <a
            href="#inicio"
            class="text-white/50 hover:text-white transition-colors">Inicio</a
          >
        </li>
        <li>
          <a
            href="#historia"
            class="text-white/50 hover:text-white transition-colors">Historia</a
          >
        </li>
        <li>
          <a
            href="#personajes"
            class="text-white/50 hover:text-white transition-colors"
            >Personajes</a
          >
        </li>
        <li>
          <a href="#" class="text-white/50 hover:text-white transition-colors"
            >Lore</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4
        class="font-cinzel text-xs tracking-[0.2em] uppercase text-white/80 mb-4"
      >
        Comunidad
      </h4>
      <ul class="space-y-3">
        <li>
          <a href="#" class="text-white/50 hover:text-white transition-colors"
            >Foros</a
          >
        </li>
        <li>
          <a href="#" class="text-white/50 hover:text-white transition-colors"
            >Guías</a
          >
        </li>
        <li>
          <a href="#" class="text-white/50 hover:text-white transition-colors"
            >Eventos</a
          >
        </li>
        <li>
          <a href="#" class="text-white/50 hover:text-white transition-colors"
            >Soporte</a
          >
        </li>
      </ul>
    </div>

    <div class="footer-social">
      <h4
        class="font-cinzel text-xs tracking-[0.2em] uppercase text-white/80 mb-3"
      >
        Síguenos
      </h4>
      <div class="social-icons-compact">
        <a href="#" aria-label="Twitter" class="social-icon-compact">
          <span class="icon">𝕏</span>
        </a>
        <a href="#" aria-label="Discord" class="social-icon-compact">
          <span class="icon">💬</span>
        </a>
        <a href="#" aria-label="Reddit" class="social-icon-compact">
          <span class="icon">👾</span>
        </a>
        <a href="#" aria-label="YouTube" class="social-icon-compact">
          <span class="icon">▶</span>
        </a>
      </div>
    </div>
  </div>

  <div
    class="max-w-7xl mx-auto pt-6 relative z-10"
    style="border-top: 1px solid rgba(155,109,255,0.08);"
  >
    <div
      class="flex flex-col md:flex-row md:justify-between md:items-center gap-2 text-center md:text-left"
    >
      <p class="text-white/30 text-xs font-mono tracking-wider">
        &copy; <span id="footer-year"></span> Hollow Knight — Hallownest. Todos los
        derechos reservados.
      </p>
      <p class="text-white/30 text-xs font-body">
        Creado con devoción por fans de Hallownest
      </p>
    </div>
  </div>

  <script>
    const yearEl = document.getElementById("footer-year");
    if (yearEl) yearEl.textContent = new Date().getFullYear().toString();
  </script>
</footer>

<style>
  .social-icons-compact {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .social-icon-compact {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(
      135deg,
      rgba(155, 109, 255, 0.15),
      rgba(0, 200, 255, 0.1)
    );
    border: 1px solid rgba(155, 109, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .social-icon-compact::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
      circle at 30% 30%,
      rgba(255, 255, 255, 0.1),
      transparent 50%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .social-icon-compact:hover {
    transform: translateY(-3px) scale(1.05);
    border-color: rgba(155, 109, 255, 0.4);
    color: #fff;
    box-shadow: 0 8px 20px rgba(155, 109, 255, 0.3);
  }

  .social-icon-compact:hover::before {
    opacity: 1;
  }

  .social-icon-compact .icon {
    font-size: 1.1rem;
    font-weight: 600;
    z-index: 1;
    position: relative;
  }

  @media (max-width: 640px) {
    .social-icons-compact {
      gap: 0.625rem;
      justify-content: center;
    }

    .social-icon-compact {
      width: 40px;
      height: 40px;
    }

    .social-icon-compact .icon {
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .social-icons-compact {
      gap: 0.5rem;
    }

    .social-icon-compact {
      width: 36px;
      height: 36px;
    }

    .social-icon-compact .icon {
      font-size: 0.875rem;
    }
  }
</style>
